{
  "$schema": "https://raw.githubusercontent.com/TradeSkillMaster/wowlua-ls/main/editors/vscode/wowluarc.schema.json",
  "ignore": [
    "*.md",
    "LICENSE",
    ".vscode/",
    ".github/",
    ".gitignore",
    ".pkgmeta",
    "Media/",
    "Modules/"
  ],
  "library": ["Libs/"],
  "framexml": true,
  "flavors": [
    "retail",
    "classic",
    "classic_era"
  ],
  "globals": {
    "read": [
      "LibStub"
    ],
    "write": [
      "SmartRes2",
      "SmartRes2DB"
    ]
  },
  "diagnostics": {
    "enable": [
      "need-check-nil"
    ]
  }
}